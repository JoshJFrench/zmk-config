#define RC(row, col) (row * 12 + col)

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <5>;
// | SW1  | SW2  | SW3  | SW4  | SW5  | SW6  |   | SW6  | SW5  | SW4  | SW3  | SW2  | SW1  |
// | SW7  | SW8  | SW9  | SW10 | SW11 | SW12 |   | SW12 | SW11 | SW10 | SW9  | SW8  | SW7  |
// | SW13 | SW14 | SW15 | SW16 | SW17 | SW18 |   | SW18 | SW17 | SW16 | SW15 | SW14 | SW13 |
// | SW19 | SW20 | SW21 | SW22 | SW23 | SW24 |   | SW24 | SW23 | SW22 | SW21 | SW20 | SW19 |
//                     | SW25 | SW26 | SW27 | SW28 | SW29 | SW30 | SW31 | SW32 | SW33 | SW34 |
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)  RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)  RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)  RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)  RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11)
                        RC(4,2) RC(4,3) RC(4,4) RC(4,5)  RC(4,6) RC(4,7) RC(4,8) RC(4,9)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        row-gpios
            = <&pro_micro_f1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* R0 */
            , <&pro_micro_f0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* R1 */
            , <&pro_micro_d0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* R2 */
            , <&pro_micro_d1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* R3 */
            , <&pro_micro_d4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* R4 */
            ;
        col-gpios
            = <&pro_micro_c6 GPIO_ACTIVE_HIGH>  /* C0 */
            , <&pro_micro_b2 GPIO_ACTIVE_HIGH>  /* C1 */
            , <&pro_micro_b3 GPIO_ACTIVE_HIGH>  /* C2 */
            , <&pro_micro_b1 GPIO_ACTIVE_HIGH>  /* C3 */
            , <&pro_micro_f7 GPIO_ACTIVE_HIGH>  /* C4 */
            , <&pro_micro_f6 GPIO_ACTIVE_HIGH>  /* C5 */
            ;
    };
    // LEFT ENCODER (Rotation: Up/Down Arrows)
    left_encoder: encoder_left {
        compatible = "alps,ec11";
        label = "Left Encoder";
        a-gpios = <&pro_micro_d5 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        b-gpios = <&pro_micro_d6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        steps = <4>; // Adjust based on your encoder
        status = "disabled";
    };
    // RIGHT ENCODER (Rotation: Left/Right Arrows)
    right_encoder: encoder_right {
        compatible = "alps,ec11";
        label = "Right Encoder";
        a-gpios = <&pro_micro_a2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        b-gpios = <&pro_micro_a3 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        steps = <4>; // Adjust based on your encoder
        status = "disabled";
    };

    sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&left_encoder &right_encoder>;
        triggers-per-rotation = <20>;
    };
};
