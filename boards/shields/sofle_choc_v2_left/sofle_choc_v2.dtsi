/* Base hardware definitions for Sofle Choc V2 with Nice!Nano V2 */

#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <5>;
        // Map must reflect 5 rows * 12 columns
        map = <
            // R0C0 to R0C11
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)  RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
            // R1C0 to R1C11
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)  RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
            // R2C0 to R2C11
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)  RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
            // R3C0 to R3C11
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)  RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11)
            // R4C0 to R4C11 (Thumb Row)
            RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5)  RC(4,6) RC(4,7) RC(4,8) RC(4,9) RC(4,10) RC(4,11)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row"; // Assumed standard Choc wiring

        // Row Pin Assignments (Nice!Nano D4-F1)
        row-gpios
            = <&pro_micro 18 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* R0 - F1 */
            , <&pro_micro 19 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* R1 - F0 */
            , <&pro_micro 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* R2 - D0 */
            , <&pro_micro 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* R3 - D1 */
            , <&pro_micro 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* R4 - D4 */
            ;
        
        // Column Pin Assignments (C0 to C11)
        col-gpios
            = <&pro_micro 10 GPIO_ACTIVE_HIGH>  /* C0 - B6 */
            , <&pro_micro 16 GPIO_ACTIVE_HIGH>  /* C1 - B5 */
            , <&pro_micro 14 GPIO_ACTIVE_HIGH>  /* C2 - B4 */
            , <&pro_micro 15 GPIO_ACTIVE_HIGH>  /* C3 - E6 */
            , <&pro_micro 6 GPIO_ACTIVE_HIGH>   /* C4 - D7 */
            , <&pro_micro 5 GPIO_ACTIVE_HIGH>   /* C5 - C6 */
            , <&pro_micro 21 GPIO_ACTIVE_HIGH>  /* C6 - A1 */
            , <&pro_micro 20 GPIO_ACTIVE_HIGH>  /* C7 - A2 */
            , <&pro_micro 1 GPIO_ACTIVE_HIGH>   /* C8 - A3 */
            , <&pro_micro 0 GPIO_ACTIVE_HIGH>   /* C9 - A4 */
            , <&pro_micro 9 GPIO_ACTIVE_HIGH>   /* C10 - A5 */
            , <&pro_micro 7 GPIO_ACTIVE_HIGH>   /* C11 - D5 */
            ;
    };
    // Encoder Hardware Definitions
    left_encoder: encoder_left {
        compatible = "alps,ec11";
        label = "Left Encoder";
        a-gpios = <&pro_micro 8 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;  /* D6 */
        b-gpios = <&pro_micro 9 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;  /* D5 */
        steps = <4>;
        status = "okay"; // MUST be set to "okay"
    };

    right_encoder: encoder_right {
        compatible = "alps,ec11";
        label = "Right Encoder";
        a-gpios = <&pro_micro 20 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; /* A2 */
        b-gpios = <&pro_micro 1 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;  /* A3 */
        steps = <4>;
        status = "okay"; // MUST be set to "okay"
    };

    sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&left_encoder &right_encoder>;
        triggers-per-rotation = <20>;
    };
};
